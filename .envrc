# --- BEGIN .envrc --------------------------------------------------
# If a manual venv folder exists, activate it; otherwise create one
if [ -d .venv ]; then
  export VIRTUAL_ENV="$PWD/.venv"
  PATH_add "$VIRTUAL_ENV/bin"
else
  # Creates an on-demand venv in .direnv/python-<hash>/
  layout python
fi
# --- END .envrc ----------------------------------------------------

