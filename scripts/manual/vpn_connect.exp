#!/usr/bin/expect -f
set timeout 30
spawn /opt/cisco/secureclient/bin/vpn connect sslvpn.ethz.ch
expect {
    "Username:" {
        send "pdylan\r"
        exp_continue
    }
    "Password:" {
        send "pgTi7HP2ZnhGaz8g6AXoM8DUGbAj9H4\r"
        exp_continue
    }
    "state: Connected" {
        exit 0
    }
    "error:" {
        exit 1
    }
    timeout {
        exit 1
    }
}
